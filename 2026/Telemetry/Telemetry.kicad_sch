	(text "100nF + 22 pF for high and very high freq filtering\n4.7uF and 10uF for bulk, some mid - low freq filtering\nstage 2 needs more power hense larger bulk\nPlace smaller value capacitors closer to the pin"
		(exclude_from_sim no)
		(at 150.876 120.65 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "53085033-7542-4dfa-9eb8-f119411dc3f1")
	)
	(text "Power Net Names:\n\nAny voltage Like 3.3v or 5v comes\nfrom a regulator on board.\n\nVBUS comes from a USB connection\n\nVCC comes from the car/anywhere \noutside the board.\n\nGND/VSS = Ground"
		(exclude_from_sim no)
		(at 99.822 29.718 0)
		(effects
			(font
				(size 1.7 1.7)
				(thickness 0.34)
				(bold yes)
			)
			(justify left)
		)
		(uuid "597b9308-945e-4220-9e96-52def90a5663")
	)
